    <DTS:Executable
      DTS:refId="Package\Log Start"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{790D913B-487C-4710-B595-2DA7D1D0FBB2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Start"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AD616EB0-84A0-4F78-B264-D3C7EDCA0055}"
          SQLTask:SqlStatementSource="INSERT INTO etl_execution_log&#xA;(&#xA;    package_name,&#xA;    step_name,&#xA;    status,&#xA;    row_count,&#xA;    log_message,&#xA;    log_dt&#xA;)&#xA;VALUES&#xA;(&#xA;    'SSIS_Demo',&#xA;    'Package Start',&#xA;    'STARTED',&#xA;    NULL,&#xA;    'SSIS package execution started',&#xA;    GETDATE()&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
