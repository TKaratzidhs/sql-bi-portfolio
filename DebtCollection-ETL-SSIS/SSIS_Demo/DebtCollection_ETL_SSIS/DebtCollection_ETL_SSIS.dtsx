        <SQLTask:SqlTaskData
          SQLTask:Connection="{AD616EB0-84A0-4F78-B264-D3C7EDCA0055}"
          SQLTask:SqlStatementSource="INSERT INTO etl_execution_log&#xA;(&#xA;    package_name,&#xA;    step_name,&#xA;    status,&#xA;    row_count,&#xA;    log_message,&#xA;    log_dt&#xA;)&#xA;VALUES&#xA;(&#xA;    'SSIS_Demo',&#xA;    'Package End',&#xA;    'SUCCESS',&#xA;    NULL,&#xA;    'SSIS package execution completed',&#xA;    GETDATE()&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
