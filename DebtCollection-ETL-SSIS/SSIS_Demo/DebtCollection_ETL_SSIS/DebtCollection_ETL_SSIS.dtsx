    <DTS:Executable
      DTS:refId="Package\Generate Cases Ids"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{9A30EFD4-50EB-403E-8F63-0CA4B99CD844}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Generate Cases Ids"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AD616EB0-84A0-4F78-B264-D3C7EDCA0055}"
          SQLTask:SqlStatementSource="UPDATE stg_cases&#xA;SET&#xA;    case_id = ISNULL(case_id, NEWID()),&#xA;    assign_id = ISNULL(assign_id, NEWID())&#xA;WHERE process_status = 'PENDING';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Generate Debtor IDs"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0869BC7B-A891-48F2-BE7F-30FAFE9007F9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Generate Debtor IDs"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AD616EB0-84A0-4F78-B264-D3C7EDCA0055}"
          SQLTask:SqlStatementSource="UPDATE stg_debtors&#xA;SET&#xA;    entity_id = ISNULL(entity_id, NEWID()),&#xA;    relation_id = ISNULL(relation_id, NEWID()),&#xA;    com_id = ISNULL(com_id, NEWID()),&#xA;    phone_id = ISNULL(phone_id, NEWID()),&#xA;    address_id = ISNULL(address_id, NEWID()),&#xA;    email_id = ISNULL(email_id, NEWID())&#xA;WHERE process_status = 'PENDING';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Generate Payments Ids"
